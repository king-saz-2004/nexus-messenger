# =========================
# Nexus Docker Production Env
# Copy this file to ".env" and set your own values.
# Never commit real secrets.
# =========================

# Required secrets (use strong random values, 32+ chars. Generate with: openssl rand -hex 32)
JWT_SECRET=replace-with-a-strong-random-secret
JWT_REFRESH_SECRET=replace-with-a-different-strong-random-secret

# Required database credentials (do not use default/weak passwords in production)
# WARNING: Changing POSTGRES_DB is unsupported unless SQL bootstrap grants are also updated. Use nexus.
POSTGRES_USER=nexus
POSTGRES_PASSWORD=replace-with-a-strong-random-db-password
POSTGRES_DB=nexus
APP_DB_USER=nexus_app
APP_DB_PASSWORD=replace-with-a-strong-random-app-db-password

# Required root bootstrap credentials (set your own)
DEFAULT_ROOT_USERNAME=change-root-username
DEFAULT_ROOT_PASSWORD=change-root-password-min-12-chars
# Keep false in production to avoid resetting an existing root password on restart.
RESET_ROOT_PASSWORD_ON_BOOT=false

# Public HTTPS origin of your deployed frontend (no trailing slash)
CLIENT_ORIGIN=https://chat.example.com

# Optional root profile
DEFAULT_ROOT_EMAIL=

# Published app port on host (single container)
BACKEND_PORT=3005

# Optional frontend API override.
# Leave empty for same-origin proxy mode.
VITE_API_BASE=

# Security settings
COOKIE_SECURE=true
COOKIE_SAME_SITE=strict
TRUST_PROXY=true
STRICT_PRODUCTION_SECURITY=true
ENFORCE_HTTPS=true

# public = anyone can sign up and immediately use the app
# private = new users remain pending until Root approves them
REGISTRATION_MODE=private

# Link previews make outbound requests from your VPS. Keep disabled unless you explicitly want this feature.
LINK_PREVIEW_ENABLED=false

# Link preview advanced settings
LINK_PREVIEW_METADATA_CACHE_TTL_SECONDS=3600
LINK_PREVIEW_NEGATIVE_CACHE_TTL_SECONDS=5
LINK_PREVIEW_FETCH_TIMEOUT_MS=4000
LINK_PREVIEW_HTML_MAX_BYTES=262144
LINK_PREVIEW_MAX_REDIRECTS=3
LINK_PREVIEW_RATE_LIMIT_WINDOW_MS=60000
LINK_PREVIEW_RATE_LIMIT_MAX=30

# Server-side preview image cache
LINK_PREVIEW_IMAGE_CACHE_ENABLED=true
LINK_PREVIEW_IMAGE_CACHE_DIR=/app/storage/link-preview-cache
LINK_PREVIEW_IMAGE_CACHE_TTL_SECONDS=86400
LINK_PREVIEW_IMAGE_CACHE_MAX_TOTAL_BYTES=524288000
LINK_PREVIEW_IMAGE_CACHE_MAX_FILE_BYTES=2097152
LINK_PREVIEW_IMAGE_CACHE_CLEANUP_INTERVAL_SECONDS=3600

# Optional mirrors for restricted internet environments
NPM_REGISTRY=https://registry.npmjs.org/
NODE_IMAGE=node:22-alpine
POSTGRES_IMAGE=postgres:15
REDIS_IMAGE=redis:7-alpine
