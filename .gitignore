# ==============================================================================
# NEXUS MESSENGER - MASTER GITIGNORE FILE
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Dependencies (Node.js / Package Managers)
# ------------------------------------------------------------------------------
node_modules/
**/node_modules/
extracted_node_modules/
**/extracted_node_modules/

# Internal AI/agent workspaces
.agents/
docs/ai/


# Log files generated by package managers
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ------------------------------------------------------------------------------
# 2. Build & Compilation Outputs
# ------------------------------------------------------------------------------
dist/
**/dist/
dist-ssr/
**/dist-ssr/
build/
**/build/
out/
**/out/
.next/
.cache/
.parcel-cache/
coverage/
**/coverage/
*.tsbuildinfo
*.esbuild

# ------------------------------------------------------------------------------
# 3. Environment Variables & Secret Configuration Files
# ------------------------------------------------------------------------------
# Ignore all .env files (which contain credentials, API keys, database URLs, etc.)
.env
.env.local
.env.*.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env.docker
.env.docker.local
*.env
*.env.*
**/.env
**/.env.*

# EXPLICITLY KEEP TEMPLATES (un-ignore .env.example files so other developers can see required keys)
!.env.example
!.env.docker.example
!**/.env.example
!**/.env.docker.example

# ------------------------------------------------------------------------------
# 4. Storage, Uploads, Logs & Process IDs
# ------------------------------------------------------------------------------
# Local user media storage (uploaded avatars and messages)
storage/
**/storage/

# App logs and process ids
logs/
**/logs/
*.log
*.pid
*.seed
*.ports
.phase12-backend.pid

# ------------------------------------------------------------------------------
# 5. Developer Temp Files & Custom Scripts (Project Specific)
# ------------------------------------------------------------------------------
# Local dev runner outputs
backend-dev-stdout.log
backend-dev-stderr.log
devall.log

# Temp files
.tmp-*.ps1
**/.tmp-*
*.local
CON

# Backend embedded DB & pg-test helper temp files
backend/.tmp-*.mjs
backend/.check-db-encoding.mjs
backend/.runtime-embedded-postgres.mjs
backend/.tmp-pg-test.mjs

# ------------------------------------------------------------------------------
# 6. Archives, Compressed Backups & Large Build Artifacts
# ------------------------------------------------------------------------------
# Ignore large binary archive files
*.zip
*.rar
*.tar
*.tar.gz
*.tgz
*.gz

# Specific backup directories / zip names in workspace root
deploy.tar.gz
nexus-main-app.tar
postgres.tar
redis.tar
Nexus--clone-deploy-folder/
backups/
nexus messenger/

