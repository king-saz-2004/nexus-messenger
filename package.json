{
  "name": "nexus-messenger",
  "private": true,
  "version": "1.0.0",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "vite",
    "db:up": "docker compose up -d postgres redis",
    "db:down": "docker compose down --remove-orphans",
    "db:reset": "docker compose down -v --remove-orphans && docker compose up -d postgres redis",
    "dev:all": "node scripts/dev-all.mjs",
    "dev:all:clean": "node scripts/clean-embedded-db.mjs && npm run dev:all",
    "generate:icons": "node scripts/generate-pwa-icons.mjs",
    "build": "npm run typecheck && vite build",
    "typecheck": "tsc --noEmit --pretty false",
    "preview": "vite preview"
  },
  "dependencies": {
    "canvas-confetti": "^1.9.4",
    "clsx": "^2.1.1",
    "dompurify": "^3.3.1",
    "emoji-picker-react": "^4.11.1",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.574.0",
    "marked": "^17.0.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "sharp": "^0.35.3",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
