{
  "name": "nexus-backend",
  "private": true,
  "version": "1.0.0",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit --pretty false",
    "start": "node dist/server.js",
    "contacts:backfill": "tsx src/scripts/backfillContactsFromDirectMessages.ts",
    "db:migrate": "tsx src/scripts/migrate.ts",
    "db:migrate:prod": "node dist/scripts/migrate.js",
    "smoke:test": "tsx src/scripts/smoke_test.ts",
    "link-preview:check": "tsx src/scripts/linkPreviewManualCheck.ts"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "emoji-regex": "^10.6.0",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "file-type": "^22.0.1",
    "helmet": "^7.1.0",
    "ipaddr.js": "^2.4.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "node-html-parser": "^7.0.2",
    "pg": "^8.21.0",
    "redis": "^5.8.2",
    "socket.io": "^4.7.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.14.0",
    "@types/pg": "^8.20.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.2"
  }
}
