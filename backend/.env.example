# ─────────────────────────────────────────────────────────────────
# Nexus Backend — Environment Configuration Template
# Copy this file to .env and fill in every value before starting.
# NEVER commit your real .env to version control.
# ─────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# Comma-separated list of allowed frontend origins (no trailing slash)
CLIENT_ORIGIN=http://localhost:3000,http://localhost:5173,http://localhost:4173

# ── Database ─────────────────────────────────────────────────────
# Credentials for PostgreSQL container
# WARNING: Changing POSTGRES_DB is unsupported unless SQL bootstrap grants are also updated. Use nexus.
POSTGRES_USER=nexus
POSTGRES_PASSWORD=replace-with-a-strong-random-db-password
POSTGRES_DB=nexus

# Credentials for App Database User
APP_DB_USER=nexus_app
APP_DB_PASSWORD=replace-with-a-strong-random-app-db-password

# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME?schema=public
DATABASE_URL=postgresql://nexus_app:replace-with-a-strong-random-app-db-password@localhost:5432/nexus?schema=public

# Optional migration database URL (uses superuser privileges if needed)
# MIGRATION_DATABASE_URL=postgresql://nexus:replace-with-a-strong-random-db-password@localhost:5432/nexus?schema=public

# ── JWT Secrets ──────────────────────────────────────────────────
# Must be at least 32 random characters. Use: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_USE_AT_LEAST_32_RANDOM_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_USE_AT_LEAST_32_RANDOM_CHARS

# Token TTL (s=seconds, m=minutes, h=hours, d=days)
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# ── Cookies ──────────────────────────────────────────────────────
# Set to true in production (requires HTTPS)
COOKIE_SECURE=false
# Options: lax | strict | none
COOKIE_SAME_SITE=lax
# Name for the CSRF cookie (3-64 chars, alphanumeric/underscore/hyphen)
CSRF_COOKIE_NAME=csrfToken

# ── Root Admin Account ───────────────────────────────────────────
# Created on first startup. Change immediately after first login.
DEFAULT_ROOT_USERNAME=change-root-username
# Min 12 chars. Must not be a common password in production.
DEFAULT_ROOT_PASSWORD=change-root-password-min-12-chars
DEFAULT_ROOT_EMAIL=

# Reset root password to DEFAULT_ROOT_PASSWORD on every startup (dev only)
RESET_ROOT_PASSWORD_ON_BOOT=false

# ── Security ─────────────────────────────────────────────────────
# Set to true to enforce HTTPS redirects
ENFORCE_HTTPS=false
# Set to true in production to enable strict security checks
STRICT_PRODUCTION_SECURITY=false
# Set to true if behind a reverse proxy (nginx, etc.)
TRUST_PROXY=false

# ── Rate Limiting ────────────────────────────────────────────────
GLOBAL_RATE_LIMIT_WINDOW_MS=60000
GLOBAL_RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10
AUTH_LOCK_WINDOW_SECONDS=900
AUTH_LOCK_MAX_ATTEMPTS=10
USER_LOOKUP_RATE_LIMIT_WINDOW_MS=60000
USER_LOOKUP_RATE_LIMIT_MAX=60
UPLOAD_RATE_LIMIT_WINDOW_MS=600000
UPLOAD_RATE_LIMIT_MAX=20

# ── Caching ──────────────────────────────────────────────────────
# Options: redis | memory
CACHE_PROVIDER=memory
REDIS_URL=redis://localhost:6379
CACHE_FALLBACK_TO_MEMORY=true
CACHE_DEFAULT_TTL_SECONDS=30

# ── Logging ──────────────────────────────────────────────────────
# Options: debug | info | warn | error
LOG_LEVEL=info
LOG_FILE_ENABLED=true
LOG_FILE_PATH=../logs/backend-error.log

# ── Database Pool ────────────────────────────────────────────────
DB_CONNECTION_LIMIT=25
DB_POOL_TIMEOUT_SECONDS=15

# public = anyone can sign up and immediately use the app
# private = new users remain pending until Root approves them
REGISTRATION_MODE=private

# ── Link Previews ────────────────────────────────────────────────
# Link previews make outbound requests from your VPS. Keep disabled unless you explicitly want this feature.
LINK_PREVIEW_ENABLED=false

LINK_PREVIEW_METADATA_CACHE_TTL_SECONDS=3600
LINK_PREVIEW_NEGATIVE_CACHE_TTL_SECONDS=5
LINK_PREVIEW_FETCH_TIMEOUT_MS=4000
LINK_PREVIEW_HTML_MAX_BYTES=262144
LINK_PREVIEW_MAX_REDIRECTS=3
LINK_PREVIEW_RATE_LIMIT_WINDOW_MS=60000
LINK_PREVIEW_RATE_LIMIT_MAX=30

# Server-side preview image cache
LINK_PREVIEW_IMAGE_CACHE_ENABLED=true
LINK_PREVIEW_IMAGE_CACHE_DIR=storage/link-preview-cache
LINK_PREVIEW_IMAGE_CACHE_TTL_SECONDS=86400
LINK_PREVIEW_IMAGE_CACHE_MAX_TOTAL_BYTES=524288000
LINK_PREVIEW_IMAGE_CACHE_MAX_FILE_BYTES=2097152
LINK_PREVIEW_IMAGE_CACHE_CLEANUP_INTERVAL_SECONDS=3600
